{
	"manifest_version": 2,
	"name": "WebHID for Firefox",
	"description": "Provides the WebHID API by connecting to a local server (needs to be installed separately).",
	"homepage_url": "https://github.com/ch4og/WebHID-for-Firefox",
	"version": "0.2.99",
	"author": "ch4og",
	"browser_specific_settings": {
		"gecko": {
			"id": "webhid@for-firefox",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},
	"content_scripts": [
		{
			"matches": [
				"<all_urls>"
			],
			"js": [
				"content_script.js"
			],
			"run_at": "document_start"
		}
	],
	"permissions": [
		"webRequest",
		"webRequestBlocking",
		"https://wootility.io/",
		"https://beta.wootility.io/"
	],
	"background": {
		"scripts": ["background.js"]
	}
}
